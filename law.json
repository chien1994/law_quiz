{
  "constitutional": {
    "title": "憲法",
    "chapters": {
      "ch2": {
        "name": "第二章 人民之權利義務",
        "sections": {
          "core": {
            "name": "核心權利與基本義務",
            "data": [
              { "id": "憲法第7條", "text": "中華民國人民，無分男女、宗教、種族、階級、黨派，在法律上一律平等。" },
              { "id": "憲法第22條", "text": "凡人民之其他自由及權利，不妨害社會秩序公共利益者，均受憲法之保障。" },
              { "id": "憲法第23條", "text": "以上各條列舉之自由權利，除為防止妨礙他人自由、避免緊急危難、維持社會秩序，或增進公共利益所必要者外，不得以法律限制之。" }
            ]
          }
        }
      }
    }
  },
  "civil": {
    "title": "民法",
    "chapters": {
      "general": {
        "name": "第一編 總則",
        "sections": {
          "core": {
            "name": "總則編核心條文",
            "data": [
              { "id": "民法第1條", "text": "民事，法律所未規定者，依習慣；無習慣者，依法理。" },
              { "id": "民法第6條", "text": "人之權利能力，始於出生，終於死亡。" },
              { "id": "民法第12條", "text": "滿十八歲為成年。" }
            ]
          }
        }
      },
      "obligations_each": {
        "name": "第二編 債 (各種之債)",
        "sections": {
          "sale": {
            "name": "第一節 買賣 (通則與效力)",
            "data": [
              { "id": "民法第345條", "text": "稱買賣者，謂當事人約定一方移轉財產權於他方，他方支付價金之契約。當事人就標的物及其價金互相同意時，買賣契約即為成立。" }
            ]
          },
          "gift": {
            "name": "第四節 贈與",
            "data": [
              { "id": "民法第406條", "text": "稱贈與者，謂當事人約定，一方以自己之財產無償給與他方，他方允受之契約。" }
            ]
          }
        }
      },
      "property": {
        "name": "第三編 物權",
        "sections": {
          "all": {
            "name": "物權通則與所有權",
            "data": [
              { "id": "民法第757條", "text": "物權除依法律或習慣外，不得創設。" },
              { "id": "民法第765條", "text": "所有人於法令限制之範圍內，得自由使用、收益、處分其所有物，並排除他人之干涉。" }
            ]
          }
        }
      },
      "family": {
        "name": "第四編 親屬",
        "sections": {
          "marriage": {
            "name": "親屬通則與婚姻章",
            "data": [
              { "id": "民法第967條", "text": "稱直系血親者，謂己身所從出或從己身所出之血親。稱旁系血親者，謂非直系血親，而與己身同源出之血親。" },
              { "id": "民法[972]條", "text": "婚約，應由男女當事人自行訂定。" }
            ]
          }
        }
      }
    }
  }
}