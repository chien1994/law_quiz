{
  "constitutional": {
    "title": "憲法",
    "chapters": {
      "ch2": {
        "name": "第二章 人民之權利義務",
        "sections": {
          "core": {
            "name": "核心權利與基本義務",
            "data": [
              { "id": "憲法第7條", "text": "中華民國人民，無分男女、宗教、種族、階級、黨派，在法律上一律平等。" },
              { "id": "憲法第22條", "text": "凡人民之其他自由及權利，不妨害社會秩序公共利益者，均受憲法之保障。" },
              { "id": "憲法第23條", "text": "以上各條列舉之自由權利，除為防止妨礙他人自由、避免緊急危難、維持社會秩序，或增進公共利益所必要者外，不得以法律限制之。" }
            ]
          }
        }
      }
    }
  },
  "civil": {
    "title": "民法",
    "chapters": {
      "general": {
        "name": "第一編 總則",
        "sections": {
          "core": {
            "name": "總則編核心條文",
            "data": [
              { "id": "民法第1條", "text": "民事，法律所未規定者，依習慣；無習慣者，依法理。" },
              { "id": "民法第6條", "text": "人之權利能力，始於出生，終於死亡。" },
              { "id": "民法第12條", "text": "滿十八歲為成年。" }
            ]
          }
        }
      }
    }
  }
}